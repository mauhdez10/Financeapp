# Local dev environment for Vite. Copy this file to .env.local (which is
# gitignored) and paste your real values. Without these, the local dev server
# can't connect to Supabase and login fails with "Connection error.
# (env vars missing)".
#
# Both values live in:
#   Vercel → Financeapp project → Settings → Environment Variables
#   OR Supabase Dashboard → Settings → API
#
# The anon key is the PUBLIC key — safe to keep in .env.local (which is
# never committed). The SERVICE_ROLE key is server-only — do NOT put it
# here, it would leak to the browser bundle.

VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJ...your-anon-public-key...
